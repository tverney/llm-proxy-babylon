{
  "name": "llm-proxy-babylon",
  "version": "0.1.0",
  "description": "Multilingual LLM proxy that optimizes non-English prompts for better quality, lower token costs, and stronger safety alignment",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/serve.ts",
    "start:build": "node dist/serve.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.967.0",
    "@aws-sdk/client-translate": "^3.967.0",
    "fastify": "^5.3.3",
    "franc": "^6.2.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/uuid": "^10.0.0",
    "fast-check": "^4.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
